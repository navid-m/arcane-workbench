{
  "name": "arcane-workbench",
  "version": "1.0.0",
  "description": "ArcaneDB Workbench — professional IDE for ArcaneDB",
  "main": "dist/main/main.js",
  "author": "Navid Momtahen",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "clean": "node scripts/clean.js",
    "prod": "npm run clean && npm run build && electron-builder build"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "monaco-editor": "^0.45.0"
  },
  "build": {
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/monaco/**"
    ]
  }
}
